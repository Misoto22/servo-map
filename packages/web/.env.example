# Copy to .env.local and fill in.
# All NEXT_PUBLIC_* vars are shipped to the browser — never put secrets here.

# Base URL of the ServoMap API (CF Worker). Falls back to http://localhost:8787 if unset.
NEXT_PUBLIC_API_URL=http://localhost:8787

# Mapbox public token. Get one at https://account.mapbox.com/access-tokens/.
# Scope it to your production and preview domains in the Mapbox dashboard.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxx
